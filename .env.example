# ─── feling. Sourcing Agent — Environment Config ───────────────────────────

# 1. Create a Telegram bot via @BotFather and paste the token here
TELEGRAM_TOKEN=your_bot_token_here

# 2. Your personal Telegram chat ID
#    Find it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# 3. How often to scan (in minutes). 30 is a good default.
#    Lower = more real-time but more aggressive scraping
POLL_INTERVAL_MINUTES=30

# ─── Weekly approved cost report (email) ───────────────────────────────────
# Reports also land in Telegram + reports/*.html even if email is unset.
REPORT_EMAIL=you@example.com
REPORT_FROM=feling@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail: use an App Password (Google Account → Security → App passwords)
SMTP_PASSWORD=your_app_password_here
# Cron: mon..sun, hour in local timezone
WEEKLY_REPORT_DAY=mon
WEEKLY_REPORT_HOUR=9
